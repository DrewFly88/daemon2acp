{
  "name": "daemon2acp",
  "title": "AtomCode ACP Agent",
  "version": "0.1.0",
  "description": "AtomCode coding agent via ACP protocol",
  "command": ["python3", "/path/to/daemon2acp/python/stdio_server.py"],
  "transport": "stdio",
  "env": {
    "DAEMON2ACP_MODE": "proxy",
    "DAEMON2ACP_AUTO_START": "1",
    "LOG_LEVEL": "info"
  }
}
